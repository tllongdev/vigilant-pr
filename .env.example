# Vigilant PR configuration. Copy to `.env` and fill in what you use.
#
# Most users don't need this file: run `vigilant init` and `vigilant model add`
# to connect GitHub and store keys (kept 0600 at ~/.config/vigilant-pr/credentials.json).
# This file is for CI/containers/power users. Precedence: real env > .env > stored keys.

# --- GitHub identity (posts reviews on your behalf) ---
# If you use the `gh` CLI and have run `gh auth login`, you can leave this unset.
# Otherwise set a token with Pull requests: read/write.
# GH_TOKEN=

# --- Model selection ---
# provider/model string. If unset, Vigilant auto-picks from whichever key below
# is present (Anthropic preferred). Examples:
#   groq/llama-3.3-70b-versatile
#   gemini/gemini-2.5-flash
#   openai/gpt-5.5
#   anthropic/claude-sonnet-4-6   (or just claude-sonnet-4-6)
# VIGILANT_MODEL=

# --- Provider API keys (set the one(s) you use) ---
# Anthropic (Claude) - the built-in default provider
# ANTHROPIC_API_KEY=
# OpenAI
# OPENAI_API_KEY=
# Groq (generous free tier)
# GROQ_API_KEY=
# Google Gemini (free tier)
# GEMINI_API_KEY=
# NVIDIA NIM (free tier)
# NVIDIA_NIM_API_KEY=
# OpenRouter
# OPENROUTER_API_KEY=
# xAI (Grok) - not to be confused with Groq above
# XAI_API_KEY=

# --- Optional model tuning ---
# VIGILANT_API_BASE=        # override base URL (e.g. self-hosted / Ollama)
# VIGILANT_TEMPERATURE=
# VIGILANT_MAX_TOKENS=

# --- Output / posting behavior ---
# Append a short visible "AI-assisted review" footnote to the summary (default on).
# VIGILANT_ATTRIBUTION=1          # set 0 to disable (also: --no-attribution)
# Preview each review and ask before posting - great while trying a new model.
# VIGILANT_REQUIRE_APPROVAL=0     # set 1 to require approval (also: --approve)

# --- AI gateway / LLM proxy (provider: gateway) ---
# Point Vigilant at any OpenAI-compatible endpoint behind an AI gateway or LLM
# proxy (LiteLLM, Portkey, Cloudflare AI Gateway, an internal enterprise gateway,
# etc.) - often for centrally-managed, lower-cost access. Set VIGILANT_MODEL=gateway/<model>
# and VIGILANT_API_BASE to the gateway's base URL, then pick ONE auth mode:
#
#   VIGILANT_MODEL=gateway/your-model-name
#   VIGILANT_API_BASE=https://gateway.example.com/v1
#
# Auth mode A - static bearer token:
# VIGILANT_API_KEY=
#
# Auth mode B - OAuth2 client-credentials (token is fetched, cached, refreshed):
# VIGILANT_OAUTH_TOKEN_URL=        # token endpoint, e.g. https://auth.example.com/oauth/token
# VIGILANT_OAUTH_CLIENT_ID=
# VIGILANT_OAUTH_CLIENT_SECRET=
# VIGILANT_OAUTH_SCOPE=            # optional
# VIGILANT_OAUTH_AUDIENCE=         # optional (some IdPs require it)
# VIGILANT_OAUTH_AUTH_STYLE=body   # "body" (default) or "basic" (HTTP Basic header)

# --- Slack watch (vigilant slack-watch) - no app, recommended ---
# Poll a channel and review PRs you're @-mentioned on. Uses a token you already
# have; no Slack app / admin approval needed.
# VIGILANT_SLACK_CHANNELS=        # comma-separated channel IDs, e.g. C0123,C0456
# VIGILANT_SLACK_USER_ID=         # optional; auto-detected from the token otherwise
# VIGILANT_SLACK_STATE_DIR=       # optional; where to persist watch state (default ~/.config/vigilant-pr)
#
# Option A (recommended): auto-read + auto-refresh the token from your Chrome
# Slack session. Needs the extra: pip install 'vigilant-pr[slack-refresh]' then
# python -m playwright install chromium. Then run with --auto-token, or set:
# VIGILANT_SLACK_AUTO_TOKEN=1
# VIGILANT_SLACK_TEAM=            # optional; force a workspace if you're in several
#
# Option B: set the token yourself (no auto-refresh).
# SLACK_TOKEN=                    # xoxc-... (session), or xoxb-/xoxp- OAuth token
# SLACK_COOKIE_D=                 # xoxd-... cookie value (required for xoxc- tokens)

# --- Teams trigger (vigilant teams-watch) ---
# VIGILANT_TEAMS_SECRET=          # base64 HMAC secret from the outgoing webhook
# VIGILANT_TEAMS_RESULT_WEBHOOK=  # incoming webhook URL to post results
